# ===========================================
# RiderGuy Environment Variables
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ===========================================

# ---- General ----
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---- Database (PostgreSQL 16 — self-hosted on Hetzner) ----
# For local development, point to your local PostgreSQL or the Hetzner server.
# In production, this connects to the local PostgreSQL instance on the VPS.
DATABASE_URL=postgresql://riderguy:your-password@127.0.0.1:5432/riderguy_db

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth / JWT ----
JWT_ACCESS_SECRET=your-jwt-access-secret-min-32-chars-change-me
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
OTP_EXPIRY_MINUTES=5

# ---- File Storage (S3-compatible: AWS S3, Cloudflare R2) ----
S3_BUCKET_NAME=riderguy-uploads
S3_REGION=auto
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# ---- Payments ----
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxx
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxx

# ---- Maps (Google Maps) ----
# Server-side key (used by API for geocoding & directions)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Client-side key (used by frontend maps)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ---- Email (SendGrid) ----
SENDGRID_API_KEY=SG.xxx
EMAIL_FROM=noreply@myriderguy.com
EMAIL_FROM_NAME=RiderGuy

# ---- SMS (mNotify — Ghana) ----
MNOTIFY_API_KEY=xxx
MNOTIFY_SENDER_ID=RiderGuy

# ---- Monitoring (Sentry) ----
SENTRY_DSN=https://xxx@sentry.io/xxx
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx

# ---- WebAuthn (Biometric / Passkey Login) ----
WEBAUTHN_RP_NAME=RiderGuy
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3002,http://localhost:3000

# ---- Push Notifications (Firebase) ----
FIREBASE_PROJECT_ID=riderguy
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@riderguy.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nxxx\n-----END PRIVATE KEY-----\n"
NEXT_PUBLIC_FIREBASE_API_KEY=xxx
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=xxx
NEXT_PUBLIC_FIREBASE_APP_ID=xxx
NEXT_PUBLIC_FIREBASE_VAPID_KEY=xxx
