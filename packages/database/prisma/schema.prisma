// ============================================================
// RiderGuy — Prisma Schema
// The single source of truth for the entire database.
// Every model here maps to a PostgreSQL table.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  RIDER
  CLIENT
  BUSINESS_CLIENT
  PARTNER
  DISPATCHER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  DEACTIVATED
  BANNED
}

enum RiderOnboardingStatus {
  REGISTERED
  DOCUMENTS_PENDING
  DOCUMENTS_SUBMITTED
  DOCUMENTS_UNDER_REVIEW
  DOCUMENTS_APPROVED
  DOCUMENTS_REJECTED
  TRAINING_PENDING
  TRAINING_COMPLETE
  ACTIVATED
}

enum RiderAvailability {
  OFFLINE
  ONLINE
  ON_DELIVERY
  ON_BREAK
}

enum VehicleType {
  BICYCLE
  MOTORCYCLE
  CAR
  VAN
  TRUCK
}

enum DocumentType {
  NATIONAL_ID
  DRIVERS_LICENSE
  VEHICLE_REGISTRATION
  INSURANCE_CERTIFICATE
  PROOF_OF_ADDRESS
  SELFIE
  VEHICLE_PHOTO_FRONT
  VEHICLE_PHOTO_BACK
  VEHICLE_PHOTO_LEFT
  VEHICLE_PHOTO_RIGHT
}

enum DocumentStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  PENDING
  SEARCHING_RIDER
  ASSIGNED
  PICKUP_EN_ROUTE
  AT_PICKUP
  PICKED_UP
  IN_TRANSIT
  AT_DROPOFF
  DELIVERED
  FAILED
  CANCELLED_BY_CLIENT
  CANCELLED_BY_RIDER
  CANCELLED_BY_ADMIN
}

enum StopType {
  PICKUP
  DROPOFF
}

enum StopStatus {
  PENDING
  EN_ROUTE
  ARRIVED
  COMPLETED
  SKIPPED
  FAILED
}

enum ScheduleFrequency {
  ONCE
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  CUSTOM
}

enum ScheduledDeliveryStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum PackageType {
  DOCUMENT
  SMALL_PARCEL
  MEDIUM_PARCEL
  LARGE_PARCEL
  FOOD
  FRAGILE
  HIGH_VALUE
  OTHER
}

enum ProofOfDeliveryType {
  PHOTO
  SIGNATURE
  PIN_CODE
  LEFT_AT_DOOR
}

enum PaymentMethod {
  CARD
  MOBILE_MONEY
  WALLET
  CASH
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum TransactionType {
  DELIVERY_EARNING
  TIP
  BONUS
  COMMISSION_DEDUCTION
  WITHDRAWAL
  DEPOSIT
  REFERRAL_COMMISSION
  REFUND
  PENALTY
  ADJUSTMENT
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PartnerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum ZoneStatus {
  ACTIVE
  INACTIVE
  FULL
}

enum OtpPurpose {
  REGISTRATION
  LOGIN
  PASSWORD_RESET
}

enum TokenPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum NotificationType {
  ORDER
  PAYMENT
  SYSTEM
  COMMUNITY
  TRAINING
  GAMIFICATION
  PROMOTION
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id             String        @id @default(cuid())
  email          String?       @unique
  phone          String        @unique
  phoneVerified  Boolean       @default(false)
  emailVerified  Boolean       @default(false)
  passwordHash   String?
  pinHash        String?
  firstName      String
  lastName       String
  avatarUrl      String?
  role           UserRole        // @deprecated — use `roles` array instead. Kept for backwards compat during migration.
  roles          UserRole[]      @default([])
  status         AccountStatus @default(PENDING_VERIFICATION)
  failedLoginAttempts Int       @default(0)
  lockedUntil    DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  riderProfile   RiderProfile?
  clientProfile  ClientProfile?
  businessAccount BusinessAccount?
  partnerProfile PartnerProfile?
  documents      Document[]
  sessions       Session[]
  wallet         Wallet?
  ordersAsClient Order[]       @relation("ClientOrders")
  scheduledDeliveries ScheduledDelivery[] @relation("ClientScheduledDeliveries")
  notifications  Notification[]
  pushTokens     PushToken[]

  // Community relations (Sprint 11)
  chatMembers       ChatMember[]
  chatMessages      ChatMessage[]
  forumPosts        ForumPost[]
  forumComments     ForumComment[]
  forumVotes        ForumVote[]
  announcements     Announcement[]     @relation("AnnouncementAuthor")
  contentReports    ContentReport[]    @relation("ContentReporter")
  pollVotes         PollVote[]

  // Sprint 12 relations
  events                Event[]              @relation("EventCreator")
  eventRsvps            EventRsvp[]
  featureRequests       FeatureRequest[]      @relation("FeatureRequestAuthor")
  featureRequestUpvotes FeatureRequestUpvote[]

  // Community places (user-contributed locations)
  communityPlaces       CommunityPlace[]

  // Promo code usages
  promoCodeUsages       PromoCodeUsage[]

  emailTokens    EmailToken[]

  @@index([phone])
  @@index([email])
  @@index([role, status])
  @@index([status])
  webauthnCredentials WebAuthnCredential[]

  @@map("users")
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo       String?
  ipAddress        String?
  refreshTokenHash String?
  lastActiveAt     DateTime @default(now())
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Otp {
  id        String     @id @default(cuid())
  phone     String
  code      String
  purpose   OtpPurpose
  attempts  Int        @default(0)
  verified  Boolean    @default(false)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
  @@map("otps")
}

model EmailToken {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String       @unique
  purpose   TokenPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("email_tokens")
}

model WebAuthnCredential {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialId  String   @unique  // base64url-encoded credential ID
  publicKey     String             // base64url-encoded public key
  counter       BigInt   @default(0)
  deviceType    String?            // "singleDevice" | "multiDevice"
  transports    String[]           // e.g. ["internal", "hybrid"]
  backedUp      Boolean  @default(false)
  friendlyName  String?            // e.g. "iPhone 15", "Pixel 8"
  createdAt     DateTime @default(now())

  @@index([userId])
  @@map("webauthn_credentials")
}

model WebAuthnChallenge {
  id        String   @id @default(cuid())
  challenge String   @unique
  userId    String?            // set during registration flow
  phone     String?            // set during login flow
  type      String             // "registration" | "authentication"
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
  @@map("webauthn_challenges")
}

// ============================================================
// RIDER
// ============================================================

model RiderProfile {
  id                 String               @id @default(cuid())
  userId             String               @unique
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  onboardingStatus   RiderOnboardingStatus @default(REGISTERED)
  availability       RiderAvailability     @default(OFFLINE)
  currentLevel       Int                  @default(1) // 1-7
  totalXp            Int                  @default(0)
  totalDeliveries    Int                  @default(0)
  averageRating      Float                @default(0)
  totalRatings       Int                  @default(0)
  completionRate     Float                @default(0)
  onTimeRate         Float                @default(0)
  currentZoneId      String?
  currentZone        Zone?                @relation(fields: [currentZoneId], references: [id], onDelete: SetNull)
  preferredVehicleType VehicleType?
  isVerified         Boolean              @default(false)
  activatedAt        DateTime?
  currentLatitude    Float?
  currentLongitude   Float?
  lastLocationUpdate DateTime?

  // ── Presence tracking — keeps API gates open while rider is ONLINE ──
  lastHeartbeat      DateTime?            // Server-side heartbeat timestamp (updated every ping)
  lastSeenAt         DateTime?            // Last time any activity detected (socket or REST)
  socketId           String?              // Current Socket.IO connection id
  isConnected        Boolean              @default(false) // True if socket is currently alive
  sessionStartedAt   DateTime?            // When the current ONLINE session began
  totalOnlineSeconds Int                  @default(0)     // Cumulative online time for analytics
  connectionQuality  String?              // "excellent" | "good" | "poor" | "disconnected"

  referredByPartnerId String?
  referredByPartner  PartnerProfile?      @relation("ReferredRiders", fields: [referredByPartnerId], references: [id])
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Relations
  vehicles           Vehicle[]
  ordersAsRider      Order[]              @relation("RiderOrders")
  partnerRecruitments PartnerRecruitment[] @relation("RecruitedRider")
  badges             RiderBadge[]
  xpEvents           XpEvent[]
  streak             RiderStreak?
  challengeParticipations ChallengeParticipant[]
  rewardRedemptions  RewardRedemption[]
  rewardPoints       Int                  @default(0) // Reward store points balance
  favoritedByClients FavoriteRider[]
  locationHistory    LocationHistory[]

  // Sprint 12 — Identity & Mentorship
  bio                String?              @db.Text
  publicProfileUrl   String?              @unique
  mentorships        Mentorship[]         @relation("MentorRelation")
  menteeships        Mentorship[]         @relation("MenteeRelation")
  spotlights         RiderSpotlight[]

  // Cancellation tracking
  cancellationCount  Int                  @default(0)
  lastCancellationAt DateTime?
  suspendedUntil     DateTime?            // Non-null = currently suspended from new orders
  cancellationRecords    CancellationRecord[]
  cancellationRequests   CancellationRequest[]

  @@index([availability])
  @@index([currentZoneId])
  @@index([onboardingStatus])
  @@index([currentLatitude, currentLongitude])
  @@index([totalXp])
  @@map("rider_profiles")
}

model Vehicle {
  id            String      @id @default(cuid())
  riderId       String
  rider         RiderProfile @relation(fields: [riderId], references: [id], onDelete: Cascade)
  type          VehicleType
  make          String
  model         String
  year          Int?
  color         String?
  plateNumber   String
  isPrimary     Boolean     @default(false)
  photoFrontUrl String?
  photoBackUrl  String?
  photoLeftUrl  String?
  photoRightUrl String?
  isApproved    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([riderId])
  @@map("vehicles")
}

// ============================================================
// CLIENT
// ============================================================

model ClientProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalOrders            Int      @default(0)
  totalSpent             Decimal  @default(0) @db.Decimal(12, 2)
  averageRating          Float    @default(0)
  defaultPaymentMethodId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  // Relations
  savedAddresses SavedAddress[]
  favoriteRiders FavoriteRider[]

  @@map("client_profiles")
}

model SavedAddress {
  id           String        @id @default(cuid())
  clientId     String
  client       ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  label        String        // e.g., "Home", "Office"
  address      String
  latitude     Float
  longitude    Float
  instructions String?
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())

  @@index([clientId])
  @@map("saved_addresses")
}

model FavoriteRider {
  id        String        @id @default(cuid())
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  riderProfileId String
  riderProfile   RiderProfile  @relation(fields: [riderProfileId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([clientId, riderProfileId])
  @@index([riderProfileId])
  @@map("favorite_riders")
}

model BusinessAccount {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName        String
  companyEmail       String
  companyPhone       String
  registrationNumber String?
  billingAddress     String?
  industry           String?
  totalOrders        Int      @default(0)
  totalSpent         Decimal  @default(0) @db.Decimal(12, 2)
  webhookUrl         String?
  webhookSecret      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  apiKeys ApiKey[]

  @@map("business_accounts")
}

model ApiKey {
  id                String          @id @default(cuid())
  businessAccountId String
  businessAccount   BusinessAccount @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  key               String          @unique
  name              String
  isActive          Boolean         @default(true)
  lastUsedAt        DateTime?
  expiresAt         DateTime?
  createdAt         DateTime        @default(now())

  @@index([key])
  @@map("api_keys")
}

// ============================================================
// DOCUMENTS
// ============================================================

model Document {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            DocumentType
  fileUrl         String
  fileName        String
  fileSizeBytes   Int
  mimeType        String
  status          DocumentStatus @default(PENDING)
  rejectionReason String?
  reviewedBy      String?
  reviewedAt      DateTime?
  expiresAt       DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId, type])
  @@index([status])
  @@map("documents")
}

// ============================================================
// ORDERS & DELIVERIES
// ============================================================

model Order {
  id                    String              @id @default(cuid())
  orderNumber           String              @unique
  clientId              String
  client                User                @relation("ClientOrders", fields: [clientId], references: [id], onDelete: Restrict)
  riderId               String?
  rider                 RiderProfile?       @relation("RiderOrders", fields: [riderId], references: [id], onDelete: SetNull)
  zoneId                String?
  zone                  Zone?               @relation(fields: [zoneId], references: [id], onDelete: SetNull)

  // Pickup
  pickupAddress         String
  pickupLatitude        Float
  pickupLongitude       Float
  pickupContactName     String?
  pickupContactPhone    String?
  pickupInstructions    String?

  // Dropoff
  dropoffAddress        String
  dropoffLatitude       Float
  dropoffLongitude      Float
  dropoffContactName    String?
  dropoffContactPhone   String?
  dropoffInstructions   String?

  // Package
  packageType           PackageType
  packageDescription    String?
  packagePhotoUrl       String?

  // Pricing
  distanceKm            Float
  routeDistanceKm       Float?             // Actual route distance from Mapbox (null = haversine used)
  estimatedDurationMinutes  Int
  baseFare              Decimal            @db.Decimal(12, 2)
  distanceCharge        Decimal            @db.Decimal(12, 2)
  surgeMultiplier       Float              @default(1.0)
  timeOfDayMultiplier   Float              @default(1.0)
  weatherMultiplier     Float              @default(1.0)
  crossZoneMultiplier   Float              @default(1.0)
  expressMultiplier     Float              @default(1.0)
  weightSurcharge       Decimal            @default(0) @db.Decimal(12, 2)
  packageWeightKg       Float?             // Declared weight
  waitTimeCharge        Decimal            @default(0) @db.Decimal(12, 2)
  waitTimeMinutes       Int                @default(0)
  businessDiscount      Float              @default(0)   // 0–1 discount rate
  promoDiscount         Decimal            @default(0) @db.Decimal(12, 2)
  promoCodeId           String?
  promoCode             PromoCode?         @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  serviceFee            Decimal            @db.Decimal(12, 2)
  serviceFeeRate        Float              @default(0.10) // Actual rate used (may vary by payment method)
  totalPrice            Decimal            @db.Decimal(12, 2)
  currency              String             @default("GHS")
  isExpress             Boolean            @default(false)

  // Payment
  paymentMethod         PaymentMethod
  paymentStatus         PaymentStatus      @default(PENDING)
  paymentReference      String?

  // Status
  status                OrderStatus        @default(PENDING)

  // Proof of delivery
  proofOfDeliveryType   ProofOfDeliveryType?
  proofOfDeliveryUrl    String?
  deliveryPinCode       String?

  // Earnings
  riderEarnings         Decimal?           @db.Decimal(12, 2)
  platformCommission    Decimal?           @db.Decimal(12, 2)
  tipAmount             Decimal            @default(0) @db.Decimal(12, 2)

  // Ratings
  clientRating          Int?
  clientReview          String?
  riderRating           Int?

  // Scheduling
  isScheduled           Boolean            @default(false)
  scheduledAt           DateTime?
  scheduleType          String?            // NOW, SAME_DAY, NEXT_DAY, RECURRING
  scheduleDiscount      Float              @default(1.0)

  // Multi-stop support
  isMultiStop           Boolean            @default(false)
  stops                 OrderStop[]
  stopsJson             Json?              // Legacy / denormalized snapshot

  // Scheduled delivery link
  scheduledDeliveryId   String?
  scheduledDelivery     ScheduledDelivery? @relation(fields: [scheduledDeliveryId], references: [id], onDelete: SetNull)

  // Failure
  failureReason         String?
  failurePhotoUrl       String?

  // Timestamps
  assignedAt            DateTime?
  pickedUpAt            DateTime?
  deliveredAt           DateTime?
  cancelledAt           DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  // Relations
  statusHistory         OrderStatusHistory[]
  messages              OrderMessage[]
  cancellationRecord    CancellationRecord?
  cancellationRequest   CancellationRequest?

  @@index([clientId])
  @@index([riderId])
  @@index([status])
  @@index([zoneId])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([scheduledDeliveryId])
  @@index([promoCodeId])
  @@map("orders")
}

// ============================================================
// MULTI-STOP: Individual pickup/dropoff stops within an order
// ============================================================

model OrderStop {
  id                String     @id @default(cuid())
  orderId           String
  order             Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  type              StopType   // PICKUP or DROPOFF
  sequence          Int        // Order in the route (1, 2, 3...)
  status            StopStatus @default(PENDING)

  // Location
  address           String
  latitude          Float
  longitude         Float
  placeId           String?    // Google/Mapbox place ID for precision

  // Contact
  contactName       String?
  contactPhone      String?
  instructions      String?

  // Proof
  proofType         ProofOfDeliveryType?
  proofUrl          String?
  pinCode           String?

  // Package info (each stop can have its own package)
  packageType       PackageType?
  packageDescription String?
  packagePhotoUrl   String?

  // Timestamps
  arrivedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([orderId])
  @@index([orderId, sequence])
  @@map("order_stops")
}

// ============================================================
// SCHEDULED & RECURRING DELIVERIES
// ============================================================

model ScheduledDelivery {
  id                  String                   @id @default(cuid())
  clientId            String
  client              User                     @relation("ClientScheduledDeliveries", fields: [clientId], references: [id], onDelete: Cascade)
  zoneId              String?

  // Schedule configuration
  title               String?                  // e.g. "Daily office supplies run"
  frequency           ScheduleFrequency        @default(ONCE)
  scheduledDate       DateTime?                // For one-time future deliveries
  scheduledTime       String?                  // HH:mm format for recurring (e.g. "09:00")
  daysOfWeek          Int[]                    // For WEEKLY: [1,3,5] = Mon/Wed/Fri (ISO day numbers)
  dayOfMonth          Int?                     // For MONTHLY: 1-31
  customCronExpression String?                  // For CUSTOM frequency
  startDate           DateTime?                // When the recurrence begins
  endDate             DateTime?                // When the recurrence ends (null = indefinite)
  maxOccurrences      Int?                     // Stop after N deliveries
  occurrenceCount     Int                      @default(0)

  // Route template (reused for each generated order)
  pickupAddress       String
  pickupLatitude      Float
  pickupLongitude     Float
  pickupContactName   String?
  pickupContactPhone  String?
  pickupInstructions  String?

  dropoffAddress      String
  dropoffLatitude     Float
  dropoffLongitude    Float
  dropoffContactName  String?
  dropoffContactPhone String?
  dropoffInstructions String?

  // Multi-stop template
  isMultiStop         Boolean                  @default(false)
  stopsTemplate       Json?                    // Array of stop templates for multi-stop scheduled orders

  // Package defaults
  packageType         PackageType?
  packageDescription  String?

  // Pricing & payment
  estimatedPrice      Decimal?             @db.Decimal(12, 2)
  currency            String                   @default("GHS")
  paymentMethod       PaymentMethod?

  // Status
  status              ScheduledDeliveryStatus  @default(ACTIVE)
  lastGeneratedAt     DateTime?
  nextScheduledAt     DateTime?

  // Timestamps
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  // Relations
  generatedOrders     Order[]

  @@index([clientId])
  @@index([status])
  @@index([nextScheduledAt])
  @@map("scheduled_deliveries")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  actor     String      // 'system', 'rider', 'client', 'admin', or a user ID
  createdAt DateTime    @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

model OrderMessage {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  senderId  String
  content   String
  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_messages")
}

// ============================================================
// LOCATION HISTORY (GPS breadcrumb trail)
// ============================================================

model LocationHistory {
  id        String   @id @default(cuid())
  riderId   String
  rider     RiderProfile @relation(fields: [riderId], references: [id], onDelete: Cascade)
  orderId   String?
  latitude  Float
  longitude Float
  heading   Float?
  speed     Float?
  createdAt DateTime @default(now())

  @@index([riderId, createdAt])
  @@index([orderId, createdAt])
  @@map("location_history")
}

// ============================================================
// WALLET & FINANCE
// ============================================================

model Wallet {
  id             String        @id @default(cuid())
  userId         String        @unique
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance        Decimal       @default(0) @db.Decimal(12, 2)
  currency       String        @default("GHS")
  totalEarned    Decimal       @default(0) @db.Decimal(12, 2)
  totalWithdrawn Decimal       @default(0) @db.Decimal(12, 2)
  totalTips      Decimal       @default(0) @db.Decimal(12, 2)
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // Relations
  transactions   Transaction[]
  withdrawals    Withdrawal[]

  @@map("wallets")
}

model Transaction {
  id            String          @id @default(cuid())
  walletId      String
  wallet        Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  balanceAfter  Decimal         @db.Decimal(12, 2)
  currency      String          @default("GHS")
  description   String
  referenceId   String?         // order ID, withdrawal ID, etc.
  referenceType String?         // 'order', 'withdrawal', 'bonus'
  metadata      Json?
  createdAt     DateTime        @default(now())

  @@index([walletId])
  @@index([walletId, createdAt])
  @@index([type])
  @@index([createdAt])
  @@index([referenceId])
  @@map("transactions")
}

model Withdrawal {
  id               String           @id @default(cuid())
  walletId         String
  wallet           Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId           String
  amount           Decimal          @db.Decimal(12, 2)
  currency         String           @default("GHS")
  method           PaymentMethod
  destination      String
  destinationName  String
  bankCode         String?
  status           WithdrawalStatus @default(PENDING)
  processedAt      DateTime?
  failureReason    String?
  paymentReference String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([walletId])
  @@index([userId])
  @@index([status])
  @@map("withdrawals")
}

// ============================================================
// ZONES
// ============================================================

model Zone {
  id              String     @id @default(cuid())
  name            String     @unique
  description     String?
  status          ZoneStatus @default(ACTIVE)
  polygon         Json       // GeoJSON polygon: number[][][]
  centerLatitude  Float
  centerLongitude Float
  baseFare        Float
  perKmRate       Float
  minimumFare     Float
  surgeMultiplier Float      @default(1.0)
  commissionRate  Float      // percentage 0-100
  roadFactor      Float      @default(1.3)  // Zone-specific road factor
  avgSpeedKmh     Float      @default(20)   // Zone-specific avg speed
  currency        String     @default("GHS")
  totalRiders     Int        @default(0)
  activeRiders    Int        @default(0)
  pendingOrders   Int        @default(0)    // For dynamic surge calculation
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  // Relations
  riders              RiderProfile[]
  orders              Order[]
  mentorships         Mentorship[]
  events              Event[]
  promoCodes          PromoCode[]

  @@index([status])
  @@map("zones")
}

// ============================================================
// PROMO CODES / COUPONS
// ============================================================

model PromoCode {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountType    DiscountType @default(PERCENTAGE)
  discountValue   Float        // percentage (0–100) or flat GHS amount
  minOrderAmount  Decimal?     @db.Decimal(12, 2) // Minimum order subtotal to qualify
  maxDiscountGhs  Decimal?     @db.Decimal(12, 2) // Cap for percentage discounts
  maxUses         Int?         // Total uses allowed (null = unlimited)
  maxUsesPerUser  Int          @default(1)
  usedCount       Int          @default(0)
  validFrom       DateTime     @default(now())
  validUntil      DateTime?
  isActive        Boolean      @default(true)
  // Targeting
  zoneId          String?      // Restrict to specific zone
  zone            Zone?        @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  packageTypes    String[]     // Restrict to specific package types (empty = all)
  forNewUsersOnly Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  orders          Order[]
  usages          PromoCodeUsage[]

  @@index([code])
  @@index([isActive, validUntil])
  @@map("promo_codes")
}

model PromoCodeUsage {
  id          String    @id @default(cuid())
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId     String?
  discount    Decimal   @db.Decimal(12, 2)
  usedAt      DateTime  @default(now())

  @@unique([promoCodeId, userId, orderId])
  @@index([userId])
  @@map("promo_code_usages")
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

// ============================================================
// PARTNER / REFERRAL PROGRAM
// ============================================================

model PartnerProfile {
  id                          String     @id @default(cuid())
  userId                      String     @unique
  user                        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  referralCode                String     @unique
  tier                        PartnerTier @default(BRONZE)
  totalRecruits               Int        @default(0)
  activeRecruits              Int        @default(0)
  totalCommissionEarned       Decimal    @default(0) @db.Decimal(12, 2)
  pendingCommission           Decimal    @default(0) @db.Decimal(12, 2)
  signUpBonusRate             Float      @default(0)
  activationBonusRate         Float      @default(0)
  ongoingCommissionRate       Float      @default(0) // percentage
  ongoingCommissionDurationDays Int      @default(90)
  isActive                    Boolean    @default(true)
  createdAt                   DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt

  // Relations
  recruitments    PartnerRecruitment[]
  referredRiders  RiderProfile[]  @relation("ReferredRiders")

  @@index([referralCode])
  @@map("partner_profiles")
}

model PartnerRecruitment {
  id                    String         @id @default(cuid())
  partnerId             String
  partner               PartnerProfile @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  riderId               String
  rider                 RiderProfile   @relation("RecruitedRider", fields: [riderId], references: [id], onDelete: Cascade)
  signUpBonusPaid       Boolean        @default(false)
  activationBonusPaid   Boolean        @default(false)
  ongoingCommissionEndsAt DateTime?
  totalCommissionEarned Decimal        @default(0) @db.Decimal(12, 2)
  createdAt             DateTime       @default(now())

  @@unique([partnerId, riderId])
  @@index([partnerId])
  @@index([riderId])
  @@map("partner_recruitments")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  type      NotificationType // Typed enum instead of plain String
  data      Json?            // arbitrary payload for deep linking
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================================
// PUSH TOKENS — stores FCM / Web Push device tokens per user
// ============================================================

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   // FCM registration token
  platform  String   // 'web', 'android', 'ios'
  deviceId  String?  // optional device identifier for de-duplication
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, token])
  @@index([userId, isActive])
  @@map("push_tokens")
}

// ============================================================
// GAMIFICATION — XP Events, Badges, Rider Badges
// ============================================================

model XpEvent {
  id          String       @id @default(cuid())
  riderId     String
  rider       RiderProfile @relation(fields: [riderId], references: [id], onDelete: Cascade)
  action      String       // e.g., "delivery_complete", "five_star_rating", "on_time", "referral", "streak"
  points      Int
  metadata    Json?        // arbitrary context (orderId, streak count, etc.)
  createdAt   DateTime     @default(now())

  @@index([riderId])
  @@index([riderId, action])
  @@index([createdAt])
  @@map("xp_events")
}

model Badge {
  id          String       @id @default(cuid())
  slug        String       @unique // machine-readable key, e.g., "first_delivery"
  name        String       // display name
  description String       // what it means
  icon        String       // emoji or icon key
  category    String       @default("achievement") // "achievement", "milestone", "special"
  criteria    Json?        // rule definition: { action: "delivery_complete", threshold: 1 }
  xpReward    Int          @default(0) // bonus XP on earning this badge
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  riders      RiderBadge[]

  @@index([category])
  @@index([isActive])
  @@map("badges")
}

model RiderBadge {
  id        String       @id @default(cuid())
  riderId   String
  rider     RiderProfile @relation(fields: [riderId], references: [id], onDelete: Cascade)
  badgeId   String
  badge     Badge        @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime     @default(now())
  seenAt    DateTime?    // null until rider dismisses the celebration

  @@unique([riderId, badgeId])
  @@index([riderId])
  @@index([badgeId])
  @@map("rider_badges")
}

// ============================================================
// SPRINT 10 — Streaks, Challenges, Rewards Store, Bonus XP Events
// ============================================================

model RiderStreak {
  id                String       @id @default(cuid())
  riderId           String       @unique
  rider             RiderProfile @relation(fields: [riderId], references: [id], onDelete: Cascade)
  currentStreak     Int          @default(0)   // consecutive active days
  longestStreak     Int          @default(0)
  lastActiveDate    DateTime?                  // last date rider completed a delivery
  streakStartDate   DateTime?                  // when the current streak started
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([currentStreak])
  @@map("rider_streaks")
}

enum ChallengeType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum ChallengeStatus {
  DRAFT
  ACTIVE
  COMPLETED
  EXPIRED
  CANCELLED
}

model Challenge {
  id            String          @id @default(cuid())
  title         String
  description   String
  type          ChallengeType
  status        ChallengeStatus @default(DRAFT)
  icon          String          @default("🎯")
  // Criteria: what action & how many to complete
  criteriaAction String         // e.g., "delivery_complete", "on_time_delivery", "five_star_rating"
  criteriaCount  Int            // e.g., 10 deliveries
  // Reward
  xpReward      Int             @default(0)
  pointsReward  Int             @default(0)   // reward store points
  badgeRewardId String?                        // optional badge awarded on completion
  // Targeting
  zoneId        String?                        // null = all zones
  minLevel      Int?                           // null = all levels
  maxLevel      Int?
  // Scheduling
  startsAt      DateTime
  endsAt        DateTime
  // Metadata
  createdBy     String?                        // admin userId who created it
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  participants  ChallengeParticipant[]

  @@index([status])
  @@index([type])
  @@index([startsAt, endsAt])
  @@map("challenges")
}

model ChallengeParticipant {
  id            String       @id @default(cuid())
  challengeId   String
  challenge     Challenge    @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  riderId       String
  rider         RiderProfile @relation(fields: [riderId], references: [id], onDelete: Cascade)
  progress      Int          @default(0)      // current count towards criteriaCount
  completedAt   DateTime?                     // null until completed
  rewardClaimed Boolean      @default(false)
  joinedAt      DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([challengeId, riderId])
  @@index([riderId])
  @@index([challengeId, completedAt])
  @@map("challenge_participants")
}

model RewardStoreItem {
  id            String    @id @default(cuid())
  name          String
  description   String
  icon          String    @default("🎁")
  imageUrl      String?
  category      String    @default("general") // "merchandise", "voucher", "perk", "general"
  pointsCost    Int                           // how many reward points to redeem
  inventory     Int       @default(-1)        // -1 = unlimited
  isFeatured    Boolean   @default(false)
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  redemptions   RewardRedemption[]

  @@index([category])
  @@index([isActive, isFeatured])
  @@map("reward_store_items")
}

enum RedemptionStatus {
  PENDING
  APPROVED
  FULFILLED
  REJECTED
  CANCELLED
}

model RewardRedemption {
  id            String           @id @default(cuid())
  riderId       String
  rider         RiderProfile     @relation(fields: [riderId], references: [id], onDelete: Cascade)
  itemId        String
  item          RewardStoreItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  pointsSpent   Int
  status        RedemptionStatus @default(PENDING)
  notes         String?          // admin notes
  fulfilledAt   DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([riderId])
  @@index([itemId])
  @@index([status])
  @@map("reward_redemptions")
}

model BonusXpEvent {
  id            String    @id @default(cuid())
  title         String                        // e.g., "Double XP Weekend"
  description   String
  multiplier    Float     @default(2.0)       // XP multiplier (2.0 = double)
  // Can target specific actions or all
  targetActions String[]  @default([])        // empty = all actions get multiplied
  // Targeting
  zoneId        String?                       // null = global
  // Scheduling
  startsAt      DateTime
  endsAt        DateTime
  isActive      Boolean   @default(true)
  // Metadata
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([isActive, startsAt, endsAt])
  @@map("bonus_xp_events")
}

// ============================================================
// COMMUNITY — Chat, Forums, Polls, Announcements (Sprint 11)
// ============================================================

enum ChatRoomType {
  ZONE        // Zone-based group chat for riders in the same area
  DIRECT      // 1:1 direct messages between riders
  ANNOUNCEMENT // Admin announcement channel (read-only for riders)
}

enum ChatMessageType {
  TEXT
  IMAGE
  VOICE
  SYSTEM      // e.g., "User joined", "Room created"
}

enum ForumPostCategory {
  GENERAL
  TIPS_TRICKS
  ROUTES
  VEHICLE_MAINTENANCE
  EARNINGS
  SAFETY
  EVENTS
  FEATURE_REQUESTS
  OFF_TOPIC
}

enum ContentReportReason {
  SPAM
  HARASSMENT
  HATE_SPEECH
  MISINFORMATION
  INAPPROPRIATE
  SCAM
  OTHER
}

enum ContentReportStatus {
  PENDING
  REVIEWED
  ACTION_TAKEN
  DISMISSED
}

enum ModerationAction {
  WARNING
  MUTE_1H
  MUTE_24H
  MUTE_7D
  BAN_FROM_ROOM
  BAN_FROM_COMMUNITY
}

// ── Chat Rooms ──

model ChatRoom {
  id          String       @id @default(cuid())
  name        String       // e.g., "Accra Central Riders", or auto-generated for DMs
  type        ChatRoomType
  zoneId      String?      // For ZONE type rooms — links to zone
  description String?
  avatarUrl   String?
  isActive    Boolean      @default(true)
  createdBy   String?      // Admin or system
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  members     ChatMember[]
  messages    ChatMessage[]

  @@unique([type, zoneId], name: "unique_zone_room") // One room per zone
  @@index([type])
  @@index([zoneId])
  @@index([isActive])
  @@map("chat_rooms")
}

model ChatMember {
  id         String    @id @default(cuid())
  roomId     String
  room       ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isMuted    Boolean   @default(false)
  mutedUntil DateTime?
  lastReadAt DateTime  @default(now())
  joinedAt   DateTime  @default(now())

  @@unique([roomId, userId])
  @@index([userId])
  @@index([roomId])
  @@map("chat_members")
}

model ChatMessage {
  id        String          @id @default(cuid())
  roomId    String
  room      ChatRoom        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User            @relation(fields: [senderId], references: [id], onDelete: Cascade)
  type      ChatMessageType @default(TEXT)
  content   String
  mediaUrl  String?         // For image/voice messages
  replyToId String?         // Reply thread reference
  isEdited  Boolean         @default(false)
  isDeleted Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  // Reactions stored as JSON: { "👍": ["userId1","userId2"], "😂": ["userId3"] }
  reactions Json?

  @@index([roomId, createdAt])
  @@index([senderId])
  @@map("chat_messages")
}

// ── Forums ──

model ForumPost {
  id         String            @id @default(cuid())
  authorId   String
  author     User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title      String
  body       String            @db.Text
  category   ForumPostCategory @default(GENERAL)
  isPinned   Boolean           @default(false)
  isLocked   Boolean           @default(false) // No new comments
  isDeleted  Boolean           @default(false)
  viewCount  Int               @default(0)
  upvotes    Int               @default(0)
  downvotes  Int               @default(0)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  // Relations
  comments   ForumComment[]
  votes      ForumVote[]
  poll       Poll?

  @@index([authorId])
  @@index([category])
  @@index([isPinned, createdAt])
  @@index([upvotes])
  @@index([createdAt])
  @@map("forum_posts")
}

model ForumComment {
  id        String   @id @default(cuid())
  postId    String
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parentId  String?  // For nested replies
  body      String   @db.Text
  isDeleted Boolean  @default(false)
  upvotes   Int      @default(0)
  downvotes Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Self-relation for nested replies
  parent    ForumComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   ForumComment[] @relation("CommentReplies")
  votes     ForumVote[]

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("forum_comments")
}

model ForumVote {
  id         String        @id @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId     String?
  post       ForumPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId  String?
  comment    ForumComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  value      Int           // +1 upvote, -1 downvote
  createdAt  DateTime      @default(now())

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@map("forum_votes")
}

// ── Polls (attached to forum posts) ──

model Poll {
  id        String       @id @default(cuid())
  postId    String       @unique
  post      ForumPost    @relation(fields: [postId], references: [id], onDelete: Cascade)
  question  String
  expiresAt DateTime?
  createdAt DateTime     @default(now())

  options   PollOption[]

  @@map("polls")
}

model PollOption {
  id        String     @id @default(cuid())
  pollId    String
  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text      String
  position  Int        @default(0) // Display order
  createdAt DateTime   @default(now())

  votes     PollVote[]

  @@index([pollId])
  @@map("poll_options")
}

model PollVote {
  id        String     @id @default(cuid())
  optionId  String
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([optionId, userId]) // One vote per user per option
  @@index([userId])
  @@map("poll_votes")
}

// ── Announcements ──

model Announcement {
  id          String   @id @default(cuid())
  authorId    String
  author      User     @relation("AnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  body        String   @db.Text
  priority    Int      @default(0) // 0=normal, 1=important, 2=urgent
  targetZones String[] @default([]) // Empty = global, otherwise zone IDs
  targetRoles UserRole[] @default([RIDER]) // Which roles see it
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isPublished, publishedAt])
  @@index([priority])
  @@map("announcements")
}

// ── Content Moderation ──

model ContentReport {
  id           String              @id @default(cuid())
  reporterId   String
  reporter     User                @relation("ContentReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reason       ContentReportReason
  description  String?
  // What was reported (polymorphic via entityType + entityId)
  entityType   String              // 'chat_message', 'forum_post', 'forum_comment'
  entityId     String
  status       ContentReportStatus @default(PENDING)
  moderatorId  String?             // Admin who reviewed
  moderatorNote String?
  actionTaken  ModerationAction?
  resolvedAt   DateTime?
  createdAt    DateTime            @default(now())

  @@index([status])
  @@index([entityType, entityId])
  @@index([reporterId])
  @@index([createdAt])
  @@map("content_reports")
}

// ============================================================
// SPRINT 12 — MENTORSHIP, EVENTS & RIDER IDENTITY
// ============================================================

enum MentorshipStatus {
  PENDING     // Awaiting mentee/mentor acceptance
  ACTIVE      // Ongoing mentorship
  COMPLETED   // Successfully completed
  CANCELLED   // Cancelled by either party
}

enum EventType {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum EventStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum FeatureRequestStatus {
  SUBMITTED
  REVIEWED
  PLANNED
  IN_PROGRESS
  SHIPPED
  DECLINED
}

// ── Mentorship ──

model Mentorship {
  id           String           @id @default(cuid())
  mentorId     String
  mentor       RiderProfile     @relation("MentorRelation", fields: [mentorId], references: [id], onDelete: Cascade)
  menteeId     String
  mentee       RiderProfile     @relation("MenteeRelation", fields: [menteeId], references: [id], onDelete: Cascade)
  status       MentorshipStatus @default(PENDING)
  zoneId       String?
  zone         Zone?            @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  startedAt    DateTime?
  completedAt  DateTime?
  completionNote String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  checkIns     MentorCheckIn[]

  @@unique([mentorId, menteeId]) // No duplicate pairings
  @@index([mentorId, status])
  @@index([menteeId, status])
  @@index([zoneId])
  @@map("mentorships")
}

model MentorCheckIn {
  id           String     @id @default(cuid())
  mentorshipId String
  mentorship   Mentorship @relation(fields: [mentorshipId], references: [id], onDelete: Cascade)
  authorId     String     // Who wrote this check-in (mentor or mentee)
  note         String     @db.Text
  rating       Int?       // 1-5 how the check-in went
  createdAt    DateTime   @default(now())

  @@index([mentorshipId])
  @@map("mentor_check_ins")
}

// ── Events ──

model Event {
  id           String      @id @default(cuid())
  title        String
  description  String      @db.Text
  type         EventType   @default(IN_PERSON)
  status       EventStatus @default(UPCOMING)
  date         DateTime
  endDate      DateTime?
  location     String?     // Physical address for in-person
  virtualLink  String?     // URL for virtual/hybrid
  imageUrl     String?
  zoneId       String?
  zone         Zone?       @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  capacity     Int?        // Max attendees (null = unlimited)
  createdById  String
  createdBy    User        @relation("EventCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  rsvps        EventRsvp[]

  @@index([status, date])
  @@index([zoneId])
  @@map("events")
}

model EventRsvp {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([eventId, userId]) // One RSVP per user per event
  @@index([userId])
  @@map("event_rsvps")
}

// ── Rider Profile / Identity ──

model RiderSpotlight {
  id          String   @id @default(cuid())
  riderId     String
  rider       RiderProfile @relation(fields: [riderId], references: [id], onDelete: Cascade)
  title       String          // e.g. "Rider of the Month — January 2026"
  story       String   @db.Text
  imageUrl    String?
  month       Int              // 1-12
  year        Int
  isFeatured  Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([month, year])    // One spotlight per month
  @@index([riderId])
  @@index([year, month])
  @@map("rider_spotlights")
}

// ── Feature Request Board ──

model FeatureRequest {
  id          String               @id @default(cuid())
  authorId    String
  author      User                 @relation("FeatureRequestAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  title       String
  description String               @db.Text
  status      FeatureRequestStatus @default(SUBMITTED)
  adminNote   String?
  upvoteCount Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  upvotes     FeatureRequestUpvote[]

  @@index([status])
  @@index([upvoteCount])
  @@index([authorId])
  @@map("feature_requests")
}

model FeatureRequestUpvote {
  id               String         @id @default(cuid())
  featureRequestId String
  featureRequest   FeatureRequest @relation(fields: [featureRequestId], references: [id], onDelete: Cascade)
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime       @default(now())

  @@unique([featureRequestId, userId]) // One upvote per user
  @@index([userId])
  @@map("feature_request_upvotes")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?  // who performed the action (null for system)
  action      String   // e.g., "user.create", "order.assign", "document.approve"
  entityType  String   // e.g., "User", "Order", "Document"
  entityId    String
  oldData     Json?
  newData     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================
// COMMUNITY PLACES — user-contributed locations that grow the
// platform's geocoding database over time. Sources:
// • Google Maps link paste (user finds it on Google Maps)
// • Manual pin drop on app map
// • Imported from external datasets
// ============================================================

model CommunityPlace {
  id              String    @id @default(cuid())
  name            String                            // display name (from reverse-geocode or user input)
  address         String?                           // full formatted address
  latitude        Float
  longitude       Float
  plusCode         String?                           // Open Location Code for areas without addresses
  placeType       String    @default("place")       // place, poi, business, landmark, etc.
  category        String?                           // shop, restaurant, hospital, school, etc.
  source          String    @default("google_maps")  // google_maps | pin_drop | imported
  googleMapsUrl   String?                           // original Google Maps link (for verification)
  contributedById String                            // user who added it
  contributedBy   User      @relation(fields: [contributedById], references: [id], onDelete: Cascade)
  usageCount      Int       @default(1)             // how many times this place has been used in orders
  verified        Boolean   @default(false)         // admin-verified or threshold-verified
  region          String?                           // region name for fast filtering (e.g., "Greater Accra")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([latitude, longitude])
  @@index([name])
  @@index([region])
  @@index([contributedById])
  @@index([source])
  @@index([usageCount])
  @@map("community_places")
}

// ============================================================
// Location Popularity — tracks how often locations are selected
// from autocomplete, enabling usage-based ranking that improves
// over time. This is the "learning" layer.
// ============================================================

model LocationPopularity {
  id              String    @id @default(cuid())
  /// Normalized search query that led to this selection
  searchQuery     String
  /// The place name that was selected
  selectedName    String
  /// Coordinates of the selected location
  latitude        Float
  longitude       Float
  /// Source provider: gazetteer, mapbox, nominatim, community
  source          String
  /// Number of times this query→place pair was selected
  selectionCount  Int       @default(1)
  /// Last time this pair was selected
  lastSelectedAt  DateTime  @default(now())
  /// Region for fast filtering
  region          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([searchQuery, selectedName])
  @@index([searchQuery])
  @@index([latitude, longitude])
  @@index([selectionCount])
  @@index([region])
  @@map("location_popularity")
}

// ============================================================
// ETA Correction Factor — stores learned correction multipliers
// for predicted vs actual delivery times, broken down by zone
// and time-of-day. Updated from completed deliveries.
// ============================================================

model EtaCorrectionFactor {
  id                  String    @id @default(cuid())
  /// Zone ID ("GLOBAL" sentinel for global fallback)
  zoneId              String    @default("GLOBAL")
  /// Hour of day (0–23) for time-of-day correction, -1 = all hours
  hourOfDay           Int       @default(-1)
  /// Day of week (0=Sunday, 6=Saturday), -1 = all days
  dayOfWeek           Int       @default(-1)
  /// Correction multiplier: actual_time / predicted_time
  /// >1.0 means predictions are too optimistic
  /// <1.0 means predictions are too pessimistic
  correctionFactor    Float     @default(1.0)
  /// Number of deliveries used to compute this factor
  sampleCount         Int       @default(0)
  /// Average predicted duration (minutes) in sample
  avgPredictedMinutes Float?
  /// Average actual duration (minutes) in sample
  avgActualMinutes    Float?
  /// Standard deviation of correction ratios
  stdDeviation        Float?
  /// Confidence: 0.0–1.0 based on sample size
  confidence          Float     @default(0.0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([zoneId, hourOfDay, dayOfWeek])
  @@index([zoneId])
  @@index([hourOfDay])
  @@map("eta_correction_factors")
}

// ============================================================
// CANCELLATION CONSEQUENCES & APPEALS
// ============================================================

enum CancellationCategory {
  VEHICLE_BREAKDOWN
  PERSONAL_EMERGENCY
  UNSAFE_CONDITIONS
  PACKAGE_ISSUE        // Too large, too heavy, prohibited item
  CANNOT_FIND_LOCATION
  CLIENT_UNREACHABLE
  PAYMENT_DISPUTE
  EXCESSIVE_WAIT
  OTHER
}

enum CancellationSeverity {
  WARNING              // No financial penalty
  MINOR                // Small fee deducted
  MODERATE             // Larger fee + short suspension
  SEVERE               // Large fee + long suspension + admin review
  CRITICAL             // Immediate account review (cancelled after pickup)
}

enum AppealStatus {
  PENDING
  UNDER_REVIEW
  APPROVED             // Consequence reversed
  PARTIALLY_APPROVED   // Penalty reduced
  DENIED
}

model CancellationRecord {
  id                  String                @id @default(cuid())

  // Who cancelled & which order
  riderId             String
  rider               RiderProfile          @relation(fields: [riderId], references: [id], onDelete: Cascade)
  orderId             String                @unique
  order               Order                 @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Reason details
  category            CancellationCategory
  reason              String                // Free-text explanation from rider
  orderStatusAtCancel String                // e.g. 'PICKED_UP', 'ASSIGNED'

  // Consequence
  severity            CancellationSeverity
  penaltyAmount       Decimal               @default(0) @db.Decimal(12, 2)
  penaltyApplied      Boolean               @default(false)
  suspensionHours     Int                   @default(0)
  suspensionApplied   Boolean               @default(false)
  requiresInvestigation Boolean             @default(false)
  investigationNotes  String?               @db.Text

  // Rolling window context at time of cancellation
  cancellationsInWindow Int                 @default(1) // How many in last 30 days

  // Evidence (optional — rider can upload proof for vehicle breakdown etc.)
  evidenceUrl         String?

  // Appeal
  appeal              CancellationAppeal?

  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([riderId])
  @@index([riderId, createdAt])
  @@index([requiresInvestigation])
  @@map("cancellation_records")
}

// ============================================================
// CANCELLATION AUTHORIZATION REQUEST
// When a rider cancels AFTER picking up the package, the client
// must authorize the cancellation to ensure package safety.
// ============================================================

enum CancelRequestStatus {
  PENDING              // Awaiting client response
  AUTHORIZED_RETURN    // Client authorized — rider must return package
  RETURN_CONFIRMED     // Client confirmed package was returned
  AUTHORIZED_COMPLETE  // Client authorized — package already returned/handed over
  DENIED               // Client denied the request
  EXPIRED              // Client didn't respond within timeout (escalates to admin)
  ADMIN_RESOLVED       // Admin intervened
}

model CancellationRequest {
  id              String              @id @default(cuid())

  // Who and which order
  riderId         String
  rider           RiderProfile        @relation(fields: [riderId], references: [id], onDelete: Cascade)
  orderId         String              @unique
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  clientId        String              // The client who must authorize

  // Request details
  reason          String              // Why the rider wants to cancel
  status          CancelRequestStatus @default(PENDING)
  orderStatusAtRequest String          // PICKED_UP or IN_TRANSIT

  // Client response
  clientResponseAt  DateTime?
  clientNote        String?           // Optional note from client

  // Admin override
  adminResolvedBy   String?           // Admin user ID if admin intervened
  adminNote         String?

  // Return tracking
  returnConfirmedAt DateTime?         // When client confirmed package return

  // Timeout: auto-expire after 30 minutes (escalate to admin)
  expiresAt       DateTime

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([riderId])
  @@index([orderId])
  @@index([clientId])
  @@index([status])
  @@index([expiresAt])
  @@map("cancellation_requests")
}

model CancellationAppeal {
  id                  String              @id @default(cuid())
  cancellationId      String              @unique
  cancellation        CancellationRecord  @relation(fields: [cancellationId], references: [id], onDelete: Cascade)
  riderId             String              // For quick lookup
  status              AppealStatus        @default(PENDING)
  riderStatement      String              @db.Text
  evidenceUrls        String[]            @default([])
  reviewedBy          String?             // Admin user ID
  reviewNotes         String?             @db.Text
  outcome             String?             // Summary of decision
  penaltyRefunded     Boolean             @default(false)
  suspensionLifted    Boolean             @default(false)
  createdAt           DateTime            @default(now())
  reviewedAt          DateTime?
  updatedAt           DateTime            @updatedAt

  @@index([riderId])
  @@index([status])
  @@map("cancellation_appeals")
}
